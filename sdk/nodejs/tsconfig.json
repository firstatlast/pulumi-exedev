{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "config/index.ts",
        "config/vars.ts",
        "domain.ts",
        "getVm.ts",
        "index.ts",
        "integration.ts",
        "provider.ts",
        "share.ts",
        "shareLink.ts",
        "sshKey.ts",
        "teamMember.ts",
        "utilities.ts",
        "vm.ts"
    ]
}
